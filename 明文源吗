function splitEntries(str) {
    return str.split(/[\s,|\n]+/).map(s => s.trim()).filter(Boolean);
}

// [修复 Bug #3] closeSocketQuietly 同时兼容 WebSocket 和 CF TCP socket
// 原代码只检查 WebSocket.OPEN，对 TCP socket（无 readyState）永远不会关闭
function closeSocketQuietly(socket) {
    try {
        if (typeof socket.readyState === 'number') {
            // WebSocket：按状态判断
            if (socket.readyState === WebSocket.OPEN || socket.readyState === WebSocket.CLOSING) {
                socket.close();
            }
        } else {
            // CF TCP socket：直接关闭
            socket.close();
        }
    } catch (_) {}
}

function base64ToArray(b64Str) {
    if (!b64Str) return { error: null };
    try {
        const binaryString = atob(b64Str.replace(/-/g, '+').replace(/_/g, '/'));
        const bytes = new Uint8Array(binaryString.length);
        for (let i = 0; i < binaryString.length; i++) {
            bytes[i] = binaryString.charCodeAt(i);
        }
        return { earlyData: bytes.buffer, error: null };
    } catch (error) {
        return { error };
    }
}

function parsePryAddress(serverStr) {
    if (!serverStr) return null;
    serverStr = serverStr.trim();
    if (serverStr.startsWith('socks://') || serverStr.startsWith('socks5://')) {
        const urlStr = serverStr.replace(/^socks:\/\//, 'socks5://');
        try {
            const url = new URL(urlStr);
            return {
                type: 'socks5',
                host: url.hostname,
                port: parseInt(url.port) || 1080,
                username: url.username ? decodeURIComponent(url.username) : '',
                password: url.password ? decodeURIComponent(url.password) : ''
            };
        } catch (_) {
            return null;
        }
    }
    if (serverStr.startsWith('http://') || serverStr.startsWith('https://')) {
        try {
            const url = new URL(serverStr);
            return {
                type: 'http',
                host: url.hostname,
                port: parseInt(url.port) || (serverStr.startsWith('https://') ? 443 : 80),
                username: url.username ? decodeURIComponent(url.username) : '',
                password: url.password ? decodeURIComponent(url.password) : ''
            };
        } catch (_) {
            return null;
        }
    }
    if (serverStr.startsWith('[')) {
        const closeBracket = serverStr.indexOf(']');
        if (closeBracket > 0) {
            const host = serverStr.substring(1, closeBracket);
            const rest = serverStr.substring(closeBracket + 1);
            if (rest.startsWith(':')) {
                const port = parseInt(rest.substring(1), 10);
                if (!isNaN(port) && port > 0 && port <= 65535) {
                    return { type: 'direct', host, port };
                }
            }
            return { type: 'direct', host, port: 443 };
        }
    }
    const lastColonIndex = serverStr.lastIndexOf(':');
    if (lastColonIndex > 0) {
        const host = serverStr.substring(0, lastColonIndex);
        const portStr = serverStr.substring(lastColonIndex + 1);
        const port = parseInt(portStr, 10);
        if (!isNaN(port) && port > 0 && port <= 65535) {
            return { type: 'direct', host, port };
        }
    }
    return { type: 'direct', host: serverStr, port: 443 };
}

function isSpeedTestSite(hostname) {
    const speedTestDomains = ['speedtest.net', 'fast.com', 'speedtest.cn', 'speed.cloudflare.com', 'ovo.speedtestcustom.com'];
    return speedTestDomains.some(domain => hostname === domain || hostname.endsWith('.' + domain));
}

async function handleSSRequest(request, customProxyIP, defaultProxyIP) {
    const wssPair = new WebSocketPair();
    const [clientSock, serverSock] = Object.values(wssPair);
    serverSock.accept();
    const remoteConnWrapper = { socket: null };
    let isDnsQuery = false;
    const earlyData = request.headers.get('sec-websocket-protocol') || '';
    const readable = makeReadableStr(serverSock, earlyData);
    readable.pipeTo(new WritableStream({
        async write(chunk) {
            if (isDnsQuery) return await forwardDnsUdp(chunk, serverSock);
            if (remoteConnWrapper.socket) {
                const writer = remoteConnWrapper.socket.writable.getWriter();
                await writer.write(chunk);
                writer.releaseLock();
                return;
            }
            const { hasError, message, addressType, port, hostname, rawIndex } = parseSSPacketHeader(chunk);
            if (hasError) throw new Error(message);
            if (isSpeedTestSite(hostname)) throw new Error('Speedtest site is blocked');
            if (addressType === 2) {
                if (port === 53) isDnsQuery = true;
                else throw new Error('UDP is not supported');
            }
            const rawData = chunk.slice(rawIndex);
            if (isDnsQuery) return forwardDnsUdp(rawData, serverSock);
            await forwardataTCP(hostname, port, rawData, serverSock, null, remoteConnWrapper, customProxyIP, defaultProxyIP);
        },
    })).catch((err) => {
        console.error('[SS pipe error]', err);
    });
    return new Response(null, { status: 101, webSocket: clientSock });
}

function parseSSPacketHeader(chunk) {
    if (chunk.byteLength < 7) return { hasError: true, message: 'Invalid data' };
    try {
        const view = new Uint8Array(chunk);
        const addressType = view[0];
        let addrValIdx = 1, addrLen = 0, hostname = '';
        switch (addressType) {
            case 1: // IPv4
                addrLen = 4;
                hostname = new Uint8Array(chunk.slice(addrValIdx, addrValIdx + addrLen)).join('.');
                addrValIdx += addrLen;
                break;
            case 3: // Domain
                addrLen = view[1];
                addrValIdx += 1;
                hostname = new TextDecoder().decode(chunk.slice(addrValIdx, addrValIdx + addrLen));
                addrValIdx += addrLen;
                break;
            case 4: { // IPv6
                addrLen = 16;
                const ipv6View = new DataView(chunk.slice(addrValIdx, addrValIdx + addrLen));
                const ipv6Parts = [];
                for (let i = 0; i < 8; i++) ipv6Parts.push(ipv6View.getUint16(i * 2).toString(16));
                hostname = ipv6Parts.join(':');
                addrValIdx += addrLen;
                break;
            }
            default:
                return { hasError: true, message: `Invalid address type: ${addressType}` };
        }
        if (!hostname) return { hasError: true, message: `Invalid address: ${addressType}` };
        const port = new DataView(chunk.slice(addrValIdx, addrValIdx + 2)).getUint16(0);
        return { hasError: false, addressType, port, hostname, rawIndex: addrValIdx + 2 };
    } catch (_) {
        return { hasError: true, message: 'Failed to parse SS packet header' };
    }
}

// [修复 Bug #2] IPv6 缩写展开（如 ::1、2001:db8::1）
// 原代码直接 split(':') 不处理缩写，导致组数不足 8 个时写入错误地址
function expandIPv6(addr) {
    addr = addr.replace(/^\[|\]$/g, '');
    if (!addr.includes('::')) {
        return addr.split(':').map(h => parseInt(h || '0', 16));
    }
    const [left, right] = addr.split('::');
    const leftGroups = left ? left.split(':').map(h => parseInt(h, 16)) : [];
    const rightGroups = right ? right.split(':').map(h => parseInt(h, 16)) : [];
    const missing = 8 - leftGroups.length - rightGroups.length;
    return [...leftGroups, ...Array(missing).fill(0), ...rightGroups];
}

async function connect2Socks5(proxyConfig, targetHost, targetPort, initialData) {
    const { host, port, username, password } = proxyConfig;
    const socket = connect({ hostname: host, port });
    const writer = socket.writable.getWriter();
    const reader = socket.readable.getReader();
    try {
        // 握手：声明支持的认证方式
        const authMethods = username && password
            ? new Uint8Array([0x05, 0x02, 0x00, 0x02])
            : new Uint8Array([0x05, 0x01, 0x00]);
        await writer.write(authMethods);

        const methodResponse = await reader.read();
        if (methodResponse.done || methodResponse.value.byteLength < 2) {
            throw new Error('S5 method selection failed');
        }
        const selectedMethod = new Uint8Array(methodResponse.value)[1];
        if (selectedMethod === 0x02) {
            if (!username || !password) throw new Error('S5 requires authentication');
            const userBytes = new TextEncoder().encode(username);
            const passBytes = new TextEncoder().encode(password);
            const authPacket = new Uint8Array(3 + userBytes.length + passBytes.length);
            authPacket[0] = 0x01;
            authPacket[1] = userBytes.length;
            authPacket.set(userBytes, 2);
            authPacket[2 + userBytes.length] = passBytes.length;
            authPacket.set(passBytes, 3 + userBytes.length);
            await writer.write(authPacket);
            const authResponse = await reader.read();
            if (authResponse.done || new Uint8Array(authResponse.value)[1] !== 0x00) {
                throw new Error('S5 authentication failed');
            }
        } else if (selectedMethod !== 0x00) {
            throw new Error(`S5 unsupported auth method: ${selectedMethod}`);
        }

        // 构建 CONNECT 请求，自动识别 IP 类型或域名
        let addrType, addrBytes;
        const ipv4Match = targetHost.match(/^(\d{1,3}\.){3}\d{1,3}$/);
        const isIPv6 = !ipv4Match && targetHost.includes(':');
        if (ipv4Match) {
            addrType = 0x01;
            addrBytes = new Uint8Array(targetHost.split('.').map(Number));
        } else if (isIPv6) {
            // [修复 Bug #2] 使用 expandIPv6 正确处理缩写形式
            addrType = 0x04;
            const groups = expandIPv6(targetHost);
            addrBytes = new Uint8Array(16);
            const dv = new DataView(addrBytes.buffer);
            groups.forEach((g, i) => dv.setUint16(i * 2, g));
        } else {
            addrType = 0x03;
            addrBytes = new TextEncoder().encode(targetHost);
        }
        const lenPrefix = addrType === 0x03 ? 1 : 0;
        const connectPacket = new Uint8Array(6 + lenPrefix + addrBytes.length);
        connectPacket[0] = 0x05;
        connectPacket[1] = 0x01;
        connectPacket[2] = 0x00;
        connectPacket[3] = addrType;
        if (addrType === 0x03) connectPacket[4] = addrBytes.length;
        connectPacket.set(addrBytes, 4 + lenPrefix);
        new DataView(connectPacket.buffer).setUint16(4 + lenPrefix + addrBytes.length, targetPort, false);
        await writer.write(connectPacket);

        const connectResponse = await reader.read();
        if (connectResponse.done || new Uint8Array(connectResponse.value)[1] !== 0x00) {
            throw new Error('S5 connection failed');
        }
        await writer.write(initialData);
        writer.releaseLock();
        reader.releaseLock();
        return socket;
    } catch (error) {
        try { writer.releaseLock(); } catch (_) {}
        try { reader.releaseLock(); } catch (_) {}
        try { socket.close(); } catch (_) {}
        throw error;
    }
}

async function connect2Http(proxyConfig, targetHost, targetPort, initialData) {
    const { host, port, username, password } = proxyConfig;
    const socket = connect({ hostname: host, port });
    const writer = socket.writable.getWriter();
    const reader = socket.readable.getReader();
    try {
        let connectRequest = `CONNECT ${targetHost}:${targetPort} HTTP/1.1\r\n`;
        connectRequest += `Host: ${targetHost}:${targetPort}\r\n`;
        if (username && password) {
            connectRequest += `Proxy-Authorization: Basic ${btoa(`${username}:${password}`)}\r\n`;
        }
        connectRequest += `User-Agent: Mozilla/5.0\r\nConnection: keep-alive\r\n\r\n`;
        await writer.write(new TextEncoder().encode(connectRequest));

        // [优化] 改用数组收集 chunk，避免每次循环全量 Uint8Array 拷贝
        const chunks = [];
        let totalLen = 0;
        let headerEndIndex = -1;
        const maxHeaderSize = 8192;
        while (totalLen < maxHeaderSize) {
            const { done, value } = await reader.read();
            if (done) throw new Error('Connection closed before receiving HTTP response');
            chunks.push(value);
            totalLen += value.length;
            // 在新 chunk 中搜索 \r\n\r\n（允许边界跨 chunk）
            const responseBuffer = mergeUint8Arrays(chunks, totalLen);
            for (let i = Math.max(0, totalLen - value.length - 3); i < responseBuffer.length - 3; i++) {
                if (responseBuffer[i] === 0x0d && responseBuffer[i + 1] === 0x0a &&
                    responseBuffer[i + 2] === 0x0d && responseBuffer[i + 3] === 0x0a) {
                    headerEndIndex = i + 4;
                    break;
                }
            }
            if (headerEndIndex !== -1) break;
        }
        if (headerEndIndex === -1) throw new Error('Invalid HTTP response');
        const responseBuffer = mergeUint8Arrays(chunks, totalLen);
        const statusLine = new TextDecoder().decode(responseBuffer.slice(0, headerEndIndex)).split('\r\n')[0];
        const statusMatch = statusLine.match(/HTTP\/\d\.\d\s+(\d+)/);
        if (!statusMatch) throw new Error(`Invalid response: ${statusLine}`);
        const statusCode = parseInt(statusMatch[1]);
        if (statusCode < 200 || statusCode >= 300) throw new Error(`Connection failed: ${statusLine}`);

        await writer.write(initialData);
        writer.releaseLock();
        reader.releaseLock();
        return socket;
    } catch (error) {
        try { writer.releaseLock(); } catch (_) {}
        try { reader.releaseLock(); } catch (_) {}
        try { socket.close(); } catch (_) {}
        throw error;
    }
}

// [优化] 辅助函数：高效合并 Uint8Array 列表
function mergeUint8Arrays(chunks, totalLen) {
    const merged = new Uint8Array(totalLen);
    let offset = 0;
    for (const chunk of chunks) {
        merged.set(chunk, offset);
        offset += chunk.length;
    }
    return merged;
}

async function forwardataTCP(host, portNum, rawData, ws, respHeader, remoteConnWrapper, customProxyIP, defaultProxyIP) {
    async function connectDirect(address, port, data) {
        const remoteSock = connect({ hostname: address, port });
        const writer = remoteSock.writable.getWriter();
        await writer.write(data);
        writer.releaseLock();
        return remoteSock;
    }

    // 解析代理配置：customProxyIP 优先，无则用 defaultProxyIP
    let proxyConfig = null;
    if (customProxyIP) {
        proxyConfig = parsePryAddress(customProxyIP);
    }
    if (!proxyConfig) {
        proxyConfig = parsePryAddress(defaultProxyIP) || { type: 'direct', host: defaultProxyIP, port: 443 };
    }

    const shouldUseProxy = proxyConfig.type === 'socks5' || proxyConfig.type === 'http' || proxyConfig.type === 'https';

    async function connecttoPry() {
        let newSocket;
        if (proxyConfig.type === 'socks5') {
            newSocket = await connect2Socks5(proxyConfig, host, portNum, rawData);
        } else if (proxyConfig.type === 'http' || proxyConfig.type === 'https') {
            newSocket = await connect2Http(proxyConfig, host, portNum, rawData);
        } else {
            newSocket = await connectDirect(proxyConfig.host, proxyConfig.port, rawData);
        }
        remoteConnWrapper.socket = newSocket;
        newSocket.closed.catch(() => {}).finally(() => closeSocketQuietly(ws));
        connectStreams(newSocket, ws, respHeader, null);
    }

    if (shouldUseProxy) {
        await connecttoPry();
    } else {
        try {
            const initialSocket = await connectDirect(host, portNum, rawData);
            remoteConnWrapper.socket = initialSocket;
            connectStreams(initialSocket, ws, respHeader, connecttoPry);
        } catch (err) {
            console.error('[direct connect failed, fallback to proxy]', err);
            await connecttoPry();
        }
    }
}

function makeReadableStr(socket, earlyDataHeader) {
    let cancelled = false;
    return new ReadableStream({
        start(controller) {
            socket.addEventListener('message', (event) => {
                if (!cancelled) controller.enqueue(event.data);
            });
            socket.addEventListener('close', () => {
                if (!cancelled) {
                    closeSocketQuietly(socket);
                    controller.close();
                }
            });
            socket.addEventListener('error', (err) => controller.error(err));
            const { earlyData, error } = base64ToArray(earlyDataHeader);
            if (error) controller.error(error);
            else if (earlyData) controller.enqueue(earlyData);
        },
        cancel() {
            cancelled = true;
            closeSocketQuietly(socket);
        }
    });
}

async function connectStreams(remoteSocket, webSocket, headerData, retryFunc) {
    let header = headerData, hasData = false;
    await remoteSocket.readable.pipeTo(
        new WritableStream({
            async write(chunk, controller) {
                hasData = true;
                if (webSocket.readyState !== WebSocket.OPEN) controller.error('wsreadyState not open');
                if (header) {
                    const response = new Uint8Array(header.length + chunk.byteLength);
                    response.set(header, 0);
                    response.set(chunk, header.length);
                    webSocket.send(response.buffer);
                    header = null;
                } else {
                    webSocket.send(chunk);
                }
            },
            abort() {},
        })
    ).catch((_) => {
        closeSocketQuietly(webSocket);
    });
    if (!hasData && retryFunc) {
        await retryFunc();
    }
}

// DNS over TCP：补充 2 字节长度前缀，符合 RFC 1035 规定
// 并正确处理 TCP 字节流边界（长度字段与数据可能跨 chunk，响应可能粘包）
async function forwardDnsUdp(udpChunk, webSocket) {
    try {
        const tcpSocket = connect({ hostname: '8.8.4.4', port: 53 });
        const writer = tcpSocket.writable.getWriter();

        // 构建带 2 字节大端序长度前缀的 DNS over TCP 数据包
        const dnsMsg = new Uint8Array(udpChunk);
        const tcpPacket = new Uint8Array(2 + dnsMsg.length);
        new DataView(tcpPacket.buffer).setUint16(0, dnsMsg.length, false);
        tcpPacket.set(dnsMsg, 2);
        await writer.write(tcpPacket);
        writer.releaseLock();

        // 正确处理 TCP 字节流：维护接收缓冲区，按 DNS over TCP 帧边界拆包
        // TCP 不保证消息边界，长度字段与数据可能跨 chunk，也可能多条响应粘包
        let buf = new Uint8Array(0);
        await tcpSocket.readable.pipeTo(new WritableStream({
            write(chunk) {
                // 追加新数据到缓冲区
                const merged = new Uint8Array(buf.length + chunk.byteLength);
                merged.set(buf, 0);
                merged.set(new Uint8Array(chunk), buf.length);
                buf = merged;

                // 循环提取完整的 DNS 消息（处理粘包：一个 chunk 可能含多条响应）
                while (buf.length >= 2) {
                    const msgLen = new DataView(buf.buffer, buf.byteOffset, 2).getUint16(0, false);
                    if (buf.length < 2 + msgLen) break; // 数据还不够，等下一个 chunk
                    const dnsResponse = buf.slice(2, 2 + msgLen);
                    if (webSocket.readyState === WebSocket.OPEN) {
                        webSocket.send(dnsResponse.buffer);
                    }
                    buf = buf.slice(2 + msgLen); // 移除已处理的帧
                }
            },
        }));
    } catch (err) {
        console.error('[DNS forward error]', err);
    }
}

// [优化] fetchRemoteCfip：改为并行请求，所有 URL 同时发出，总耗时取决于最慢的一个而不是所有之和
async function fetchRemoteCfip(urls) {
    const results = await Promise.allSettled(
        urls.map(url =>
            fetch(url, {
                signal: AbortSignal.timeout(5000),
                headers: { 'User-Agent': 'Mozilla/5.0' }
            })
            .then(resp => {
                if (!resp.ok) return [];
                return resp.text().then(text =>
                    text
                        .split(/[\n,]/)
                        .map(s => s.trim())
                        .filter(s => s.length > 0 && !s.startsWith('#'))
                );
            })
            .catch(err => {
                console.error('[fetchRemoteCfip error]', url, err);
                return [];
            })
        )
    );
    return results.flatMap(r => r.status === 'fulfilled' ? r.value : []);
}

// 反向代理伪装首页
async function getDisguisePage(request, disguiseUrl) {
    const target = disguiseUrl || 'https://example.com';
    try {
        const proxyReq = await fetch(target, {
            method: 'GET',
            headers: {
                'User-Agent': request.headers.get('User-Agent') || 'Mozilla/5.0',
                'Accept': request.headers.get('Accept') || 'text/html',
                'Accept-Language': request.headers.get('Accept-Language') || 'zh-CN,zh;q=0.9',
            },
            redirect: 'follow',
            signal: AbortSignal.timeout(8000),
        });
        const respHeaders = new Headers();
        for (const key of ['content-type', 'cache-control', 'expires', 'last-modified', 'etag']) {
            if (proxyReq.headers.has(key)) respHeaders.set(key, proxyReq.headers.get(key));
        }
        const contentType = proxyReq.headers.get('content-type') || '';
        if (contentType.includes('text/html')) {
            const targetUrl = new URL(target);
            const targetOrigin = targetUrl.origin;
            let html = await proxyReq.text();
            // [优化] 伪装页反代：同时替换绝对路径引用为相对路径，避免静态资源 404
            // 原代码只将 origin 替换为空字符串，会破坏 JS/JSON 中的 URL 并导致资源加载失败
            const escapedOrigin = targetOrigin.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            html = html.replace(new RegExp(escapedOrigin, 'g'), '');
            // 补全无协议的绝对路径（//example.com/...）
            const escapedHost = targetUrl.host.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            html = html.replace(new RegExp(`//${escapedHost}`, 'g'), '');
            return new Response(html, { status: proxyReq.status, headers: respHeaders });
        }
        return new Response(proxyReq.body, { status: proxyReq.status, headers: respHeaders });
    } catch (err) {
        console.error('[getDisguisePage error]', err);
        return new Response(
            `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Welcome</title></head><body><h1>Welcome</h1><p>Service is running.</p></body></html>`,
            { status: 200, headers: { 'Content-Type': 'text/html;charset=utf-8' } }
        );
    }
}

export default {
    async fetch(request, env) {
        try {
            // ========== 每请求局部变量（避免并发串号）==========
            const proxyIP = env.PROXYIP ? env.PROXYIP.split(',')[0].trim() : DEFAULT_PROXY_IP;

            const password = env.UUID || DEFAULT_PASSWORD;
            const rawSubPath = env.SUB_PATH || DEFAULT_SUB_PATH;
            const rawSSpath = env.SSPATH || DEFAULT_SSPATH;
            const disguiseUrl = env.DISGUISE_URL || 'https://example.com';

            const subPath = (rawSubPath === 'link' || rawSubPath === '') ? password : rawSubPath;
            const SSpath = rawSSpath === '' ? password : rawSSpath;
            const validPath = `/${SSpath}`;

            // CFIP：局部副本，不污染全局
            const localCfip = env.CFIP ? splitEntries(env.CFIP) : [...cfip];

            const url = new URL(request.url);
            const pathname = url.pathname;

            // ── /proxyip=xxx ──────────────────────────────────────
            let activeProxyIP = proxyIP;
            if (pathname.startsWith('/proxyip=')) {
                try {
                    const pathProxyIP = decodeURIComponent(pathname.substring(9)).trim();
                    if (pathProxyIP) activeProxyIP = pathProxyIP;
                } catch (_) {}
